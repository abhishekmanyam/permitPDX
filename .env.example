# Portland Permit Assistant — environment template.
# Copy to .env and fill in real values. .env is gitignored.

# AWS
AWS_PROFILE=cd
AWS_REGION=us-west-2

# Bedrock Knowledge Base + AgentCore (see infra/outputs.json)
KNOWLEDGE_BASE_ID=
AGENT_RUNTIME_ARN=

# HeyGen LiveAvatar
LIVEAVATAR_API_KEY=
LIVEAVATAR_CONTEXT_ID=
LIVEAVATAR_LLM_CONFIG_ID=
LIVEAVATAR_SANDBOX_AVATAR=

# Mapbox (frontend)
MAPBOX_TOKEN=

# Twilio — inbound webhook only; no API credentials required.
TWILIO_PHONE_NUMBER=
